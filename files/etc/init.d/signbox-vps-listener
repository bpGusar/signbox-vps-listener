#!/bin/sh /etc/rc.common

USE_PROCD=1
START=99
STOP=01

start_service() {
	local enabled

	enabled="$(uci -q get signbox-vps-listener.main.enabled)"
	[ "$enabled" = "1" ] || return 0

	mkdir -p /var/run/signbox-vps-listener /var/state/signbox-vps-listener

	/usr/libexec/signbox-vps-listener/ensure-log-file.sh >/dev/null 2>&1 || true
	/usr/libexec/signbox-vps-listener/log.sh "service: starting"

	procd_open_instance
	procd_set_param command /usr/libexec/signbox-vps-listener/stream.sh
	procd_set_param respawn 3600 5 0
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

stop_service() {
	/usr/libexec/signbox-vps-listener/log.sh "service: stopping" 2>/dev/null || true
	rm -f /var/run/signbox-vps-listener/connected
}

service_triggers() {
	procd_add_reload_trigger signbox-vps-listener
}
